#incluir<portugues.lang>;

numero a = 0;
numero b = 0;
numero c = 0;
numero media = 0;

escreva("Insere o primeiro nota:");
leia(numero, a);

escreva("Insere o segundo nota:");
leia(numero, b);

escreva("Insere o terceiro nota:");
leia(numero, c);

media: numero = (a + b + c) / 3;

se(media >= 10){
    escreva("aprovado");
}
senao se(media >= 7){
     escreva("recurso");
}
senao{
     escreva("reprovado");
}

escreva("Com media", media);