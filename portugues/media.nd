#incluir<portugues.lang>;

numero a = 0;
numero b = 0;
numero c = 0;
numero media = 0;

escreva("Insere o primeiro valor:");
leia(numero,a);

escreva("Insere o segundo valor:");
leia(numero,       b    );

escreva("Insere o terceiro valor:");
leia(  numero, c);

media: numero = (a + b + c) / 3;

escreva(media);