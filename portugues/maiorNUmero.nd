#incluir<portugues.lang>;

numero valorA = 0;
numero valorB = 0;

escreva("Insere o primeiro valor:");
leia(numero,valorA);

escreva("Insere o segundo valor:");
leia(numero,valorB);

se(valorA > valorB){
    escreva("Maior: ", valorA);
} se senao(valorA == valorB){
    escreva("Igual", valorA);
} senao{
    escreva("Maior: ", valorB);
}